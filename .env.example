# Dynamic Schema - Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Required Settings
# =============================================================================

# Django Secret Key - Generate a new one for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
POSTGRES_DB=dynamic_schema
POSTGRES_USER=dynamic_schema
POSTGRES_PASSWORD=your-database-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SCHEMA=s7,public

# =============================================================================
# Django Settings
# =============================================================================

# Debug mode - NEVER enable in production (0 or 1, true or false)
DJANGO_DEBUG=1

# Allowed hosts - Comma-separated list
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Optional Settings
# =============================================================================

# Timezone (default: America/Mexico_City)
TIME_ZONE=America/Mexico_City

# Language code (default: en-us)
LANGUAGE_CODE=en-us

# =============================================================================
# Production Settings (enable when DEBUG=False)
# =============================================================================

# Static files URL for production
# STATIC_URL=/static/

# Media files URL for production
# MEDIA_URL=/media/

# Email configuration for production
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
